{
  "info": {
    "_postman_id": "8a7109f4-2a5b-4c99-a2d1-2ce15d809e0f",
    "name": "Order Inventory Microservices",
    "description": "Postman collection for the Order, Inventory, and API Gateway services. The collection pre-request script generates a local HS256 Bearer JWT using the demo Docker secret.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function base64Url(input) {",
          "  return CryptoJS.enc.Base64.stringify(input)",
          "    .replace(/=+$/, '')",
          "    .replace(/\\+/g, '-')",
          "    .replace(/\\//g, '_');",
          "}",
          "",
          "const secret = pm.collectionVariables.get('jwtSecret');",
          "const now = Math.floor(Date.now() / 1000);",
          "const header = { alg: 'HS256', typ: 'JWT' };",
          "const payload = {",
          "  sub: 'postman-user',",
          "  iss: 'local-dev',",
          "  iat: now,",
          "  exp: now + 3600,",
          "  scope: 'orders inventory metrics docs'",
          "};",
          "",
          "const encodedHeader = base64Url(CryptoJS.enc.Utf8.parse(JSON.stringify(header)));",
          "const encodedPayload = base64Url(CryptoJS.enc.Utf8.parse(JSON.stringify(payload)));",
          "const signingInput = encodedHeader + '.' + encodedPayload;",
          "const signature = base64Url(CryptoJS.HmacSHA256(signingInput, secret));",
          "pm.collectionVariables.set('jwtToken', signingInput + '.' + signature);",
          "",
          "if (!pm.collectionVariables.get('productId')) {",
          "  const suffix = Date.now().toString() + '-' + Math.random().toString(16).slice(2, 8);",
          "  pm.collectionVariables.set('productId', 'postman-' + suffix);",
          "}",
          "if (!pm.collectionVariables.get('idempotencyKey')) {",
          "  pm.collectionVariables.set('idempotencyKey', 'order-' + Date.now() + '-' + Math.random().toString(16).slice(2, 8));",
          "}"
        ]
      }
    }
  ],
